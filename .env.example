LLM_API_KEY=
USE_API=1
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1
LIMIT_LLM_API_CALLS=100
LLM_API_TIMEOUT_SECONDS=120
REPORT_EVERY_DAYS=3
CYCLES_PER_DAY=2400
DEVIL_CHANCE_ONE_IN=10
DEVIL_AUTO_APPROVE=0
WAIT_FOR_HUMAN_VALIDATION=1
SIMULATION_DAYS=100
SIMULATION_DELAY_MS=500
SIMULATION_RENDER_EVERY_DAYS=1
PORT=3000
AUTOPOIESIS_UI=web
AUTOPOIESIS_BACKEND_RESTART=1
# Fréquence maximale de projection des instantanés vers chaque navigateur.
AUTOPOIESIS_WEB_SNAPSHOT_MS=100
# À réserver aux previews publiques : interdit les approbations réelles.
AUTOPOIESIS_SAFE_PREVIEW=0
VALIDATOR_MODE=human
VALIDATOR_MAX_REFORMULATIONS=3
EVOLUTION_AUTOSTART=1
MACOS_NOTIFICATIONS=1
GOD_QUEUE_TIMEOUT_SECONDS=900
GOD_WAIT_TIMEOUT_SECONDS=900
GOD_MAX_CORRECTIONS=2
# Facultatif : chemin absolu du binaire Codex si le PATH ne le contient pas.
CODEX_BIN=
# Modèles des instances Codex, utilisés par les scripts d'évolution.
CODEX_VALIDATOR_MODEL=gpt-5.6-sol
CODEX_VALIDATOR_REASONING_EFFORT=low
CODEX_GOD_MODEL=gpt-5.6-sol
CODEX_GOD_REASONING_EFFORT=low
# Facultatif : réutiliser un identifiant pour reprendre le budget d'un run après redémarrage.
AUTOPOIESIS_RUN_ID=
